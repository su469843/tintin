# TTS 第三方 API 配置
# 【生产环境】在 Vercel Dashboard 中设置 TTS_API_KEY（无 VITE_ 前缀）
# 【开发环境】在本 .env 文件中设置 TTS_API_KEY
# 留空则自动降级为浏览器内置 Web Speech API（无需 key）
TTS_API_KEY=
TTS_API_URL=https://tts.519965.xyz/v1/audio/speech
TTS_VOICE=en-US-JennyNeural

# Neon PostgreSQL 连接字符串（从 Neon Dashboard 获取）
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Neon Auth URL（从 Neon Dashboard → Project Settings → Auth 获取）
# VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.c-9.us-east-1.aws.neon.tech/neondb/auth
